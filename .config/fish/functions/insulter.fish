    set INSULTS[40] "This is why you get to see your children only once a month."
    set INSULTS[41] "This is why nobody likes you."
    set INSULTS[42] "Are you even trying?!"

    set count (count $INSULTS)
    echo -e '\033[0;31m'$INSULTS[(random 1 $count)]
    echo -e "Fish: Unknown command: $command"
    return 127
end
