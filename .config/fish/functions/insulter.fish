    set INSULTS[10] "Your application for reduced salary has been sent!"
    set INSULTS[11] "lol"
    set INSULTS[12] "u suk"
    set INSULTS[13] "lol... plz"
    set INSULTS[14] "plz uninstall"
    set INSULTS[15] "And the Darwin Award goes to.... $USER!"
    set INSULTS[16] "ERROR_INCOMPETENT_USER"
    set INSULTS[17] "Incompetence is also competence"
    set INSULTS[18] "Bad."
    set INSULTS[19] "Fake it till you make it!"
    set INSULTS[20] "What is this...? Amateur hour!?"
    set INSULTS[21] "Come on! You can do it!"
    set INSULTS[22] "Nice try."
